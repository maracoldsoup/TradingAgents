# Low-cost / free pilot preset for TradingAgents.
# Copy selected lines into .env when running screening or content pilots.

TRADINGAGENTS_OUTPUT_LANGUAGE=Korean
TRADINGAGENTS_LOCAL_ONLY=true

# Option A: local, keyless pilot through Ollama.
# Start Ollama separately and pull a model first, e.g. `ollama pull qwen3:latest`.
TRADINGAGENTS_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
TRADINGAGENTS_QUICK_THINK_LLM=qwen3:latest
TRADINGAGENTS_DEEP_THINK_LLM=qwen3:latest

# Option B: low-cost Google pilot. Requires GOOGLE_API_KEY in your private .env.
# TRADINGAGENTS_LLM_PROVIDER=google
# TRADINGAGENTS_QUICK_THINK_LLM=gemini-3.1-flash-lite
# TRADINGAGENTS_DEEP_THINK_LLM=gemini-3.1-flash-lite
# TRADINGAGENTS_GOOGLE_THINKING_LEVEL=minimal

# Keep first-pass pilots narrow. These settings reduce LLM call count and
# avoid bursty free-tier rate limits.
TRADINGAGENTS_MAX_DEBATE_ROUNDS=0
TRADINGAGENTS_MAX_RISK_ROUNDS=0
TRADINGAGENTS_PARALLEL_ANALYSTS=false
TRADINGAGENTS_CHECKPOINT_ENABLED=true
TRADINGAGENTS_LLM_MAX_RETRIES=1

# Optional Toss Securities read-only probe.
# Official docs: https://developers.tossinvest.com/docs
# Existing TOSS_SECURITIES_API_KEY / TOSS_SECURITIES_SECRET_KEY names are accepted too.
# TOSS_SECURITIES_BASE_URL=https://openapi.tossinvest.com
# TOSS_SECURITIES_CLIENT_ID=
# TOSS_SECURITIES_CLIENT_SECRET=
